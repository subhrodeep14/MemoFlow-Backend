generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("EMPLOYEE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String?
  name      String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([role])
  @@map("users")
}

model Company {
  id              String   @id @default(cuid())

  name            String   @unique

  code            String   @unique



  isSystemCompany Boolean  @default(false)

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  adminCode       String   @unique

  employeeCode    String   @unique

  receivedEntries Entry[]  @relation("ReceiverCompany")

  sentEntries     Entry[]  @relation("SenderCompany")

  users           User[]

  @@index([name])

  @@index([code])

  @@index([adminCode])

  @@index([employeeCode])

  @@index([isSystemCompany])

  @@map("companies")
}
model Purpose {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   Entry[]

  @@index([name])
  @@index([code])
  @@map("purposes")
}

model Entry {
  id                String   @id @default(cuid())
  slNo              Int      @unique
  memoNumber        String   @unique
  senderCompanyId   String
  receiverCompanyId String
  purposeId         String
  sendCount         Int      @default(1)
  description       String?
  fileUrl           String?
  fileName          String?
  fileMime          String?
  date              DateTime @db.Date
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  purpose           Purpose  @relation(fields: [purposeId], references: [id], onDelete: Cascade)
  receiverCompany   Company  @relation("ReceiverCompany", fields: [receiverCompanyId], references: [id], onDelete: Cascade)
  senderCompany     Company  @relation("SenderCompany", fields: [senderCompanyId], references: [id], onDelete: Cascade)

  @@index([slNo])
  @@index([date])
  @@index([memoNumber])
  @@index([senderCompanyId])
  @@index([receiverCompanyId])
  @@index([purposeId])
  @@map("entries")
}
